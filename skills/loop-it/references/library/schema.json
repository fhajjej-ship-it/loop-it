{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Loop It Library",
  "type": "object",
  "required": ["version", "loops"],
  "properties": {
    "version": {
      "type": "string"
    },
    "loops": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "category",
          "summary",
          "aliases",
          "bestFor",
          "avoidWhen",
          "defaultObjective",
          "defaultCheck",
          "maxIterations",
          "stopConditions",
          "approvalGates",
          "questions",
          "body",
          "progressSignals",
          "requiredSignals",
          "goodExamples",
          "badExamples",
          "exampleChecks",
          "commonMisroutes",
          "reliability",
          "userGuide"
        ],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "category": { "type": "string" },
          "summary": { "type": "string" },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "bestFor": { "type": "array", "items": { "type": "string" } },
          "avoidWhen": { "type": "array", "items": { "type": "string" } },
          "defaultObjective": { "type": "string" },
          "defaultCheck": { "type": "string" },
          "maxIterations": { "type": "integer", "minimum": 1 },
          "stopConditions": { "type": "array", "items": { "type": "string" } },
          "approvalGates": { "type": "array", "items": { "type": "string" } },
          "questions": { "type": "array", "items": { "type": "string" } },
          "body": { "type": "string" },
          "progressSignals": {
            "type": "object",
            "required": ["keywords"],
            "properties": {
              "keywords": { "type": "array", "items": { "type": "string" } }
            }
          },
          "requiredSignals": { "type": "array", "items": { "type": "string" } },
          "goodExamples": { "type": "array", "items": { "type": "string" } },
          "badExamples": { "type": "array", "items": { "type": "string" } },
          "exampleChecks": { "type": "array", "items": { "type": "string" } },
          "commonMisroutes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["query", "reason"],
              "properties": {
                "query": { "type": "string" },
                "preferLoopId": { "type": "string" },
                "reason": { "type": "string" }
              }
            }
          },
          "reliability": {
            "type": "object",
            "required": ["status", "summary", "bestWhen", "failsWhen", "requiredCheck"],
            "properties": {
              "status": {
                "type": "string",
                "enum": ["experimental", "tested", "proven"]
              },
              "summary": { "type": "string" },
              "bestWhen": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              },
              "failsWhen": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              },
              "requiredCheck": { "type": "string" }
            }
          },
          "userGuide": {
            "type": "object",
            "required": ["plainLanguage", "useWhen", "starterRequest", "firstStep", "proofTip", "notFor"],
            "properties": {
              "plainLanguage": { "type": "string" },
              "useWhen": { "type": "string" },
              "starterRequest": { "type": "string" },
              "firstStep": { "type": "string" },
              "proofTip": { "type": "string" },
              "notFor": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
